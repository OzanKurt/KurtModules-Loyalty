includes:
    - vendor/larastan/larastan/extension.neon
parameters:
    level: 8
    paths:
        - src
    tmpDir: build/phpstan
    ignoreErrors:
        # Public API trait for the consuming app's User model; unused inside the package by design.
        - identifier: trait.unused
          path: src/Concerns/IsLoyaltyCustomer.php
